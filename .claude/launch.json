{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI Server",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "src.main:app", "--reload"],
      "port": 8000
    },
    {
      "name": "Tests (pytest)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "pytest", "tests/", "-v"],
      "port": null
    }
  ]
}
